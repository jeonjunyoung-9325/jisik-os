{
  "name": "jisik-os",
  "version": "0.1.0",
  "private": true,
  "description": "개인용 지식 운영체제 MVP",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "db:migrate:local": "wrangler d1 execute DB --local --file=drizzle/0000_initial.sql",
    "db:seed:local": "wrangler d1 execute DB --local --file=drizzle/seed.sql",
    "db:migrate:remote": "wrangler d1 execute DB --remote --file=drizzle/0000_initial.sql",
    "db:seed:remote": "wrangler d1 execute DB --remote --file=drizzle/seed.sql",
    "db:types": "wrangler types --experimental-include-runtime=worker-configuration.d.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  }
}
